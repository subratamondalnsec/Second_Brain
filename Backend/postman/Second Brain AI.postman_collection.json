{
  "info": {
    "_postman_id": "4a40cf8a-8968-4d8f-b665-7f32250e2409",
    "name": "Second Brain AI - Backend API",
    "description": "Postman collection for Second Brain AI backend. Covers Health, Auth, Upload, Chat (Upload Mode), and Query Mode. Image uploads use direct Cloudinary upload via file.tempFilePath (no base64 encoding). Requires express-fileupload middleware with useTempFiles: true.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Set manually after login, or auto-set by Login/Signup test scripts."
    },
    {
      "key": "uploadedImageUrl",
      "value": "",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": { "type": "text/javascript", "exec": [] }
    },
    {
      "listen": "test",
      "script": { "type": "text/javascript", "exec": [] }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Public health endpoint.",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "description": "Register a new user account.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Aritra Das\",\n  \"email\": \"aritra@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "signup"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "description": "Login and get JWT token. Test script auto-sets {{token}}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aritra@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Protected endpoint. Requires valid JWT.",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Upload an image file directly to Cloudinary via file.tempFilePath (no base64 encoding). Requires express-fileupload with useTempFiles: true. Returns secure_url from Cloudinary.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/upload/image",
              "host": ["{{base_url}}"],
              "path": ["api", "upload", "image"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.imageUrl) {",
                  "    pm.collectionVariables.set('uploadedImageUrl', jsonData.imageUrl);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Chat — Upload Mode",
      "item": [
        {
          "name": "Add Text Entry (today)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Completed the backend models for Second Brain AI\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/chat/entry/text",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "entry", "text"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Add Image Entry — today (direct Cloudinary upload)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Image file — uploaded via file.tempFilePath directly to Cloudinary (no base64 encoding). Requires express-fileupload middleware with useTempFiles: true."
                },
                {
                  "key": "caption",
                  "value": "Screenshot of the project architecture",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/chat/entry/image",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "entry", "image"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Chat History (date list)",
          "request": {
            "method": "GET",
            "header": [
