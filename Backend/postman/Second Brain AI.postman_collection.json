                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Query Mode",
      "item": [
        {
          "name": "Send Query",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "description": "Sends a query. No DB storage. Logs the query on the server. RAG integration coming soon.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What did I upload about the project architecture?\"\n}",
