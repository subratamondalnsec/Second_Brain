        {
          "name": "Get Chat By Date",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Fetch entries for a specific date (YYYY-MM-DD). Past dates are read-only. Change the date in the URL as needed.",
            "url": {
              "raw": "{{base_url}}/api/chat/2026-03-21",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "2026-03-21"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
